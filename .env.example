# Build #5: Review Generation Machine - Environment Configuration
# Copy this file to .env and fill in your values

# GoHighLevel API
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Google Business Profile
GOOGLE_REVIEW_LINK=https://g.page/r/your-review-link/review

# n8n Configuration
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
N8N_WEBHOOK_PATH=ghl-settled-won

# Optional: Slack notifications for attorney alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# SMS Settings
SEND_REAL_SMS=false
SMS_SEND_WINDOW_START=10
SMS_SEND_WINDOW_END=18

# Google Business API (for review detection)
GOOGLE_BUSINESS_ACCOUNT_ID=your_account_id
GOOGLE_BUSINESS_LOCATION_ID=your_location_id
GOOGLE_API_KEY=your_google_api_key
